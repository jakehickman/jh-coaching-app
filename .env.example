# Copy this file to .env and fill in real values. Never commit .env.

# --- Database (MySQL-compatible, e.g. PlanetScale, Railway, RDS, TiDB Cloud) ---
DATABASE_URL=mysql://user:password@host:3306/database

# --- Session cookies ---
# Any long random string. Generate one with: openssl rand -base64 48
JWT_SECRET=

# --- Admin / coach account ---
# The email address that should automatically get the "admin" (coach) role
# and be auto-approved on first sign-in. This should be your own email.
OWNER_EMAIL=

# --- Google Sign-In ---
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
# Client ID (type: Web application). Add
# "<your-domain>/api/oauth/callback" (and the localhost equivalent for
# local dev) as an Authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Same client ID, exposed to the frontend build (Vite requires the VITE_ prefix)
VITE_GOOGLE_CLIENT_ID=

# --- File storage (progress photos, meal-log photos) ---
S3_BUCKET=
AWS_REGION=
# Standard AWS SDK credentials — the SDK reads these automatically, no
# extra code needed. Not required if hosting on AWS with an IAM role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: only set this if serving the bucket through a CDN/custom domain
# (e.g. CloudFront) instead of the default S3 URL.
S3_PUBLIC_BASE_URL=

# --- Misc ---
NODE_ENV=development
PORT=3000
